{
	"name": "prompt-kit",
	"version": "0.0.1",
	"author": {
		"name": "Yogev Boaron Ben-Har"
	},
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"files": [
		"templates",
		"dist/index.js"
	],
	"scripts": {
		"build": "tsc",
		"start": "node dist/index.js",
		"prepare": "volta setup && husky",
		"test": "vitest run",
		"test:watch": "vitest",
		"dev": "node src/index.ts"
	},
	"volta": {
		"node": "22.19.0"
	},
	"lint-staged": {
		"!(*.ts)": "prettier --write --ignore-unknown",
		"*.(js|ts|tsx)": [
			"prettier --write",
			"eslint --fix"
		]
	},
	"devDependencies": {
		"@eslint/js": "9.36.0",
		"@types/node": "24.5.2",
		"eslint": "9.36.0",
		"eslint-config-prettier": "10.1.8",
		"husky": "9.1.7",
		"lint-staged": "16.2.0",
		"prettier": "3.6.2",
		"typescript": "5.9.2",
		"typescript-eslint": "8.44.1",
		"vitest": "3.2.4"
	}
}
